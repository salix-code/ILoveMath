{
  "name": "ilovmath-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=../backend/static/js/main.js && esbuild src/question.ts --bundle --outfile=../backend/static/js/question.js",
    "build:prod": "esbuild src/main.ts --bundle --minify --outfile=../backend/static/js/main.js && esbuild src/question.ts --bundle --minify --outfile=../backend/static/js/question.js",
    "watch": "esbuild src/main.ts --bundle --outfile=../backend/static/js/main.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
